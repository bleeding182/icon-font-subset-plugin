# Auto-detect text files and normalize line endings to LF on commit
* text=auto eol=lf

# Shell scripts must always be LF
*.sh text eol=lf
gradlew text eol=lf

# Windows batch files must always be CRLF
*.bat text eol=crlf

# Binary files
*.ttf binary
*.jar binary
*.webp binary
*.so binary
*.dll binary
*.dylib binary
